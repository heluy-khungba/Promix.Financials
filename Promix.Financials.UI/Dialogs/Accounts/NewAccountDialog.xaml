<ContentDialog
    x:Class="Promix.Financials.UI.Dialogs.Accounts.NewAccountDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:Promix.Financials.UI.Converters"
    mc:Ignorable="d"
    FlowDirection="RightToLeft"
    Title="إنشاء حساب جديد"
    PrimaryButtonText="✔ إنشاء"
    CloseButtonText="إلغاء"
    DefaultButton="Primary"
    CornerRadius="16"
    MinWidth="800">

    <ContentDialog.Resources>
        <converters:BoolToCollapsedVisibilityConverter x:Key="BoolToCollapsedVisibilityConverter"/>
    </ContentDialog.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="580">
        <StackPanel Spacing="0">

            <!-- Banner أزرق -->
            <Border Background="#2563EB"
                    CornerRadius="12,12,0,0"
                    Padding="20,16">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Width="46" Height="46"
                            Background="#FFFFFF22"
                            CornerRadius="12"
                            VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE80F;"
                                  FontSize="22"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                        <TextBlock Text="إنشاء حساب جديد"
                                   Foreground="White"
                                   FontSize="17"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="الكود يُولَّد تلقائياً من الحساب الأب • الاسم العربي إلزامي"
                                   Foreground="#BFDBFE"
                                   FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Body -->
            <Border Background="#F1F5F9"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1,0,1,1"
                    CornerRadius="0,0,12,12"
                    Padding="20,18">
                <StackPanel Spacing="18">

                    <!-- Row 1: الحساب الأب + الكود -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="170"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8A0;" FontSize="12" Foreground="#2563EB"/>
                                <TextBlock Text="الحساب الأب"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#374151"/>
                            </StackPanel>
                            <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                      ItemsSource="{Binding ParentAccounts}"
                                      SelectedItem="{Binding SelectedParentAccount, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayName"
                                      PlaceholderText="(جذر الشجرة)"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8B3;" FontSize="12" Foreground="#2563EB"/>
                                <TextBlock Text="الكود (تلقائي)"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#374151"/>
                            </StackPanel>
                            <Border Background="White"
                                    BorderBrush="#2563EB"
                                    BorderThickness="2"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    MinHeight="42">
                                <TextBlock Text="{Binding SuggestedCode}"
                                           FontSize="18" FontWeight="Bold"
                                           Foreground="#2563EB"
                                           Language="en-US"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="#CBD5E1"/>

                    <!-- Row 2: الأسماء -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE8D2;" FontSize="12" Foreground="#2563EB"/>
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#374151">
                                    <Run Text="الاسم بالعربية"/>
                                    <Run Text=" *" Foreground="#DC2626"/>
                                </TextBlock>
                            </StackPanel>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding ArabicName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="مثال: الصندوق الرئيسي"/>
                            <TextBlock Text="{Binding ArabicNameError}"
                                       Foreground="#DC2626"
                                       FontSize="11"
                                       Visibility="{Binding IsArabicNameValid, Converter={StaticResource BoolToCollapsedVisibilityConverter}}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE8D2;" FontSize="12" Foreground="#94A3B8"/>
                                <TextBlock Text="الاسم بالإنكليزية (اختياري)"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#374151"/>
                            </StackPanel>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding EnglishName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="e.g. Main Cash"
                                     FlowDirection="LeftToRight"/>
                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="#CBD5E1"/>

                    <!-- Row 3: النوع + العملة + التصنيف -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE7C1;" FontSize="12" Foreground="#2563EB"/>
                                <TextBlock Text="نوع الحساب"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#374151"/>
                            </StackPanel>
                            <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                      ItemsSource="{Binding AccountTypes}"
                                      SelectedItem="{Binding SelectedAccountType, Mode=TwoWay}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE8EE;" FontSize="12" Foreground="#2563EB"/>
                                <TextBlock Text="العملة"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#374151"/>
                            </StackPanel>
                            <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                      ItemsSource="{Binding Currencies}"
                                      SelectedItem="{Binding SelectedCurrency, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayName"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE946;" FontSize="12" Foreground="#2563EB"/>
                                <TextBlock Text="التصنيف (تلقائي)"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#374151"/>
                            </StackPanel>
                            <Border Background="White"
                                    BorderBrush="#2563EB"
                                    BorderThickness="1.5"
                                    CornerRadius="8"
                                    Padding="10,10"
                                    MinHeight="42">
                                <TextBlock Text="{Binding DerivedCategoryText}"
                                           Foreground="#1D4ED8"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="#CBD5E1"/>

                    <!-- Row 4: الدور + الحالة -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE8D7;" FontSize="12" Foreground="#2563EB"/>
                                <TextBlock Text="الدور النظامي (اختياري)"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#374151"/>
                            </StackPanel>
                            <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                      ItemsSource="{Binding SystemRoles}"
                                      SelectedItem="{Binding SelectedSystemRole, Mode=TwoWay}"
                                      PlaceholderText="بدون"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Bottom">
                            <TextBlock Text="الحالة"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#374151"/>
                            <Border Background="White"
                                    BorderBrush="#CBD5E1"
                                    BorderThickness="1.5"
                                    CornerRadius="8"
                                    Padding="10,4">
                                <ToggleSwitch IsOn="{Binding IsActive, Mode=TwoWay}"
                                             OnContent="نشط"
                                             OffContent="غير نشط"
                                             Margin="0"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="#CBD5E1"/>

                    <!-- Row 5: الملاحظات -->
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE70B;" FontSize="12" Foreground="#94A3B8"/>
                            <TextBlock Text="ملاحظات (اختياري)"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#374151"/>
                        </StackPanel>
                        <TextBox Style="{StaticResource MultilineTextBoxStyle}"
                                 Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="أي ملاحظات إضافية..."
                                 Height="72"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>