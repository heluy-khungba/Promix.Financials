<ContentDialog
    x:Class="Promix.Financials.UI.Dialogs.Accounts.EditAccountDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    FlowDirection="RightToLeft"
    Title="تعديل الحساب"
    PrimaryButtonText="حفظ"
    CloseButtonText="إلغاء"
    DefaultButton="Primary"
    MinWidth="480">

    <StackPanel Spacing="16" Padding="4">

        <!-- معلومات ثابتة للعرض فقط -->
        <Border Background="#F1F5F9"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12,10">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="كود الحساب"
                               FontSize="11"
                               Foreground="#94A3B8"/>
                    <TextBlock Text="{Binding Code}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Language="en-US"
                               Foreground="#2563EB"/>
                    <TextBlock Text="(لا يمكن تعديل الكود)"
                               FontSize="10"
                               Foreground="#94A3B8"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="نوع الحساب"
                               FontSize="11"
                               Foreground="#94A3B8"/>
                    <TextBlock Text="{Binding TypeText}"
                               FontSize="13"
                               Foreground="#475569"/>
                    <TextBlock Text="{Binding CurrencyDisplay}"
                               FontSize="11"
                               Language="en-US"
                               Foreground="#94A3B8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- تنبيه حساب نظام -->
        <Border Background="#FEF3C7"
                BorderBrush="#F59E0B"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10,8">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE7BA;"
                          Foreground="#B45309"
                          FontSize="13"/>
                <TextBlock Text="هذا حساب نظام — بعض التعديلات غير مسموحة"
                           Foreground="#92400E"
                           FontSize="12"
                           FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <!-- الاسم العربي -->
        <StackPanel Spacing="6">
            <TextBlock Text="الاسم العربي *"
                       FontSize="12"
                       Foreground="#475569"
                       FontWeight="SemiBold"/>
            <TextBox Text="{Binding ArabicName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="أدخل الاسم العربي"
                     MinHeight="38"/>
        </StackPanel>

        <!-- الاسم الإنكليزي -->
        <StackPanel Spacing="6">
            <TextBlock Text="الاسم الإنكليزي"
                       FontSize="12"
                       Foreground="#475569"
                       FontWeight="SemiBold"/>
            <TextBox Text="{Binding EnglishName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     FlowDirection="LeftToRight"
                     PlaceholderText="English name (optional)"
                     MinHeight="38"/>
        </StackPanel>

        <!-- ملاحظات -->
        <StackPanel Spacing="6">
            <TextBlock Text="ملاحظات"
                       FontSize="12"
                       Foreground="#475569"
                       FontWeight="SemiBold"/>
            <TextBox Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="ملاحظات إضافية..."
                     MinHeight="70"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"/>
        </StackPanel>

        <!-- حالة الحساب -->
        <StackPanel Orientation="Horizontal" Spacing="12">
            <ToggleSwitch IsOn="{Binding IsActive, Mode=TwoWay}"
                          OnContent="فعّال"
                          OffContent="موقوف"
                          Margin="0"/>
        </StackPanel>

    </StackPanel>
</ContentDialog>