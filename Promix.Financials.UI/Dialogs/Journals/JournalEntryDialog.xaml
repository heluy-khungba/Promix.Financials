<ContentDialog
    x:Class="Promix.Financials.UI.Dialogs.Journals.JournalEntryDialog"
    x:Name="RootDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title=""
    PrimaryButtonText="حفظ كمسودة"
    SecondaryButtonText="حفظ وترحيل"
    CloseButtonText="إلغاء"
    DefaultButton="Primary"
    FlowDirection="RightToLeft">

    <ScrollViewer MaxHeight="720" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="18">
            <Border CornerRadius="24" Padding="22" MinHeight="148">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0F172A" Offset="0"/>
                        <GradientStop Color="#1D4ED8" Offset="0.55"/>
                        <GradientStop Color="#38BDF8" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="8">
                        <TextBlock Text="سند جديد" Foreground="White" FontSize="26" FontWeight="Bold"/>
                        <TextBlock Text="قيود يومية وسندات قبض وصرف بواجهة سريعة ومتوازنة محاسبياً."
                                   Foreground="#DBEAFE"
                                   TextWrapping="WrapWholeWords"
                                   MaxWidth="560"/>
                        <Border Background="#1E3A8A" CornerRadius="14" Padding="12,10" Margin="0,6,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="سيتم توليد الرقم تلقائياً" Foreground="White" FontWeight="SemiBold"/>
                                <TextBlock Text="•" Foreground="#93C5FD"/>
                                <TextBlock Text="{Binding BalanceStateText}" Foreground="{Binding BalanceStateBrush}" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Column="1"
                            HorizontalAlignment="Right"
                            Width="120"
                            Height="120"
                            CornerRadius="60"
                            Background="#172554">
                        <FontIcon Glyph="&#xE8A5;"
                                  Foreground="White"
                                  FontSize="54"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="White"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="18">
                    <StackPanel Spacing="12">
                        <TextBlock Text="بيانات السند" FontSize="16" FontWeight="Bold"/>
                        <ComboBox Header="النوع"
                                  ItemsSource="{Binding TypeOptions}"
                                  SelectedItem="{Binding SelectedType, Mode=TwoWay}"
                                  DisplayMemberPath="Text"/>
                        <DatePicker Header="التاريخ"
                                    Date="{Binding EntryDate, Mode=TwoWay}"/>
                        <TextBox Header="المرجع"
                                 Text="{Binding ReferenceNo, Mode=TwoWay}"
                                 PlaceholderText="مثال: دفعة موقع - مشروع فيلا"/>
                        <TextBox Header="الوصف"
                                 Text="{Binding Description, Mode=TwoWay}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="92"
                                 PlaceholderText="وصف مختصر يظهر في اليومية"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="White"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="18">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="ملخص التوازن" FontSize="16" FontWeight="Bold"/>

                        <Grid Grid.Row="1" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#EFF6FF" CornerRadius="16" Padding="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="المدين" Foreground="#64748B"/>
                                    <TextBlock Text="{Binding TotalDebit, Mode=OneWay}" FontSize="24" FontWeight="Bold" Foreground="#1D4ED8"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="#ECFDF5" CornerRadius="16" Padding="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="الدائن" Foreground="#64748B"/>
                                    <TextBlock Text="{Binding TotalCredit, Mode=OneWay}" FontSize="24" FontWeight="Bold" Foreground="#16A34A"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="#FEF2F2" CornerRadius="16" Padding="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="الفرق" Foreground="#64748B"/>
                                    <TextBlock Text="{Binding Difference, Mode=OneWay}" FontSize="24" FontWeight="Bold" Foreground="{Binding BalanceStateBrush}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="2"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14,12">
                            <TextBlock Text="الحفظ كمسودة هنا يعني المراجعة قبل الترحيل، وليس حفظ سند ناقص."
                                       TextWrapping="WrapWholeWords"
                                       Foreground="#475569"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Background="#FFFFFF"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="20"
                    Padding="18">
                <StackPanel Spacing="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="سطور السند" FontSize="18" FontWeight="Bold"/>
                        <Button Grid.Column="1"
                                Content="+ إضافة سطر"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Click="AddLine_Click"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Lines}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="12"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8FAFC"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="16">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.6*"/>
                                            <ColumnDefinition Width="1.4*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0"
                                                  Header="الحساب"
                                                  ItemsSource="{Binding DataContext.AccountOptions, ElementName=RootDialog}"
                                                  SelectedValuePath="Id"
                                                  DisplayMemberPath="DisplayText"
                                                  SelectedValue="{Binding SelectedAccountId, Mode=TwoWay}"/>
                                        <TextBox Grid.Column="1"
                                                 Header="الوصف"
                                                 Text="{Binding Description, Mode=TwoWay}"
                                                 PlaceholderText="شرح السطر"/>
                                        <NumberBox Grid.Column="2"
                                                   Header="مدين"
                                                   Value="{Binding Debit, Mode=TwoWay}"
                                                   SmallChange="1000"
                                                   SpinButtonPlacementMode="Compact"/>
                                        <NumberBox Grid.Column="3"
                                                   Header="دائن"
                                                   Value="{Binding Credit, Mode=TwoWay}"
                                                   SmallChange="1000"
                                                   SpinButtonPlacementMode="Compact"/>
                                        <Button Grid.Column="4"
                                                VerticalAlignment="Bottom"
                                                Content="✕"
                                                Background="#FEE2E2"
                                                Foreground="#DC2626"
                                                BorderBrush="#FECACA"
                                                BorderThickness="1"
                                                Padding="10,8"
                                                CornerRadius="12"
                                                Click="RemoveLine_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border x:Name="ErrorBanner"
                    Background="#FEF2F2"
                    BorderBrush="#FECACA"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14,12"
                    Visibility="Collapsed">
                <TextBlock x:Name="ErrorText" Foreground="#DC2626" TextWrapping="WrapWholeWords"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
