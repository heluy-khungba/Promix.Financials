<UserControl
    x:Class="Promix.Financials.UI.Controls.AppSidebar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource SidebarBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Padding="18,18,18,10" Spacing="10">
            <TextBlock Text="Promix" Foreground="White" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="Financials" Foreground="#C7D2FE" FontSize="12"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Padding="12,6,12,12" Spacing="8">
            <Button x:Name="BtnDashboard" x:Uid="Sidebar_Dashboard" Click="Dashboard_Click" Style="{StaticResource SidebarNavButtonStyle}"/>
            <Button x:Name="BtnChartOfAccounts"
              Content="الحسابات"
                Click="ChartOfAccounts_Click"
                   Style="{StaticResource SidebarNavButtonStyle}"/>
            <Button x:Name="BtnItems" x:Uid="Sidebar_Items" Click="Items_Click" Style="{StaticResource SidebarNavButtonStyle}"/>
            <Button x:Name="BtnReports" x:Uid="Sidebar_Reports" Click="Reports_Click" Style="{StaticResource SidebarNavButtonStyle}"/>
            <Button x:Name="BtnSettings" x:Uid="Sidebar_Settings" Click="Settings_Click" Style="{StaticResource SidebarNavButtonStyle}"/>

            <Border Height="1" Background="#2D4A76" Margin="0,10,0,6"/>

            <Border Background="#24466E" CornerRadius="14" Padding="12">
                <StackPanel Spacing="6">
                    <TextBlock Text="Quick Stats" Foreground="#C7D2FE" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="• Cash: —" Foreground="White" FontSize="12"/>
                    <TextBlock Text="• Today: —" Foreground="White" FontSize="12"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="2" Padding="12,10,12,14" Spacing="10">
            <Border Background="#24466E" CornerRadius="14" Padding="12">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="36" Height="36" CornerRadius="18" Background="#3B82F6">
                        <TextBlock Text="U" Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock x:Name="UserNameText" Text="User" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock x:Name="CompanyText" Text="Company" Foreground="#C7D2FE" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Button x:Uid="Sidebar_Logout" Click="Logout_Click" Style="{StaticResource SidebarLogoutButtonStyle}"/>
        </StackPanel>
    </Grid>
</UserControl>