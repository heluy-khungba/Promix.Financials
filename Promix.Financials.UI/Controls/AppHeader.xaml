<UserControl
    x:Class="Promix.Financials.UI.Controls.AppHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Height="64"
          Background="{StaticResource CardBackgroundBrush}"
          BorderBrush="{StaticResource BorderBrushSoft}"
          BorderThickness="0,0,0,1"
          Padding="24,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel VerticalAlignment="Center">
            <TextBlock x:Uid="Dashboard_Title"
                       Foreground="{StaticResource PrimaryTextBrush}"
                       FontWeight="Bold"
                       FontSize="17"/>
            <TextBlock x:Uid="Dashboard_Subtitle"
                       Foreground="{StaticResource MutedTextBrush}"
                       FontSize="12"
                       Margin="0,2,0,0"/>
        </StackPanel>

        <Border Grid.Column="1"
                VerticalAlignment="Center"
                Background="#F1F5F9"
                CornerRadius="8"
                Padding="12,6"
                Margin="12,0,0,0">
            <TextBlock x:Name="DateText"
                       Foreground="{StaticResource SlateTextBrush}"
                       FontSize="12"
                       FontWeight="SemiBold"/>
        </Border>

        <Border Grid.Column="2"
                VerticalAlignment="Center"
                Background="{StaticResource AppBackgroundBrush}"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12,6"
                Width="380"
                HorizontalAlignment="Center">
            <TextBox x:Name="SearchBox"
                     BorderThickness="0"
                     Background="Transparent"/>
        </Border>

        <Button Grid.Column="3"
                VerticalAlignment="Center"
                Margin="15,0,0,0"
                Content="⚙"
                Width="50"
                Height="50"
                        Click="Settings_Click"

                ToolTipService.ToolTip="{x:Bind SettingsTooltip, Mode=OneTime}"/>
    </Grid>
</UserControl>